{
  "playwright": {
    "command": "npx",
    "args": ["-y", "@playwright/mcp@latest"],
    "includeTools": [
      "browser_navigate",
      "browser_snapshot",
      "browser_click",
      "browser_type",
      "browser_fill_form",
      "browser_select_option",
      "browser_press_key",
      "browser_wait_for",
      "browser_evaluate",
      "browser_console_messages",
      "browser_network_requests",
      "browser_network_request",
      "browser_take_screenshot",
      "browser_tabs",
      "browser_close",
      "browser_resize"
    ]
  }
}
